# Prose generation (primary).
# By default LudLLM routes Anthropic-family calls through the local Claude Code
# CLI (your subscription, no metered spend) — ANTHROPIC_API_KEY is then unused.
# Set LUDLLM_USE_CLAUDE_CLI=0 to bill the metered API instead (CI, or no `claude`
# on PATH); that path needs the key below.
ANTHROPIC_API_KEY=
# LUDLLM_USE_CLAUDE_CLI=0

# Adversarial critique / blind-reader eval (cross-family)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (sensible defaults if unset).
# Drafter/author default to Sonnet (cost-effective for a full novel); point the
# drafter at Opus for hero chapters. Extractor defaults to Haiku.
# LUDLLM_DRAFTER_MODEL=claude-sonnet-4-6
# LUDLLM_AUTHOR_MODEL=claude-sonnet-4-6
# LUDLLM_EXTRACTOR_MODEL=claude-haiku-4-5
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-5.1
